node_modules/
.DS_Store
*.log
*.tsbuildinfo

# Playwright artifacts (never commit these).
playwright-report/
test-results/
playwright/.cache/

# IDE.
.idea/
.vscode/
*.code-workspace

# Env / secrets.
.env
.env.local
.env.*.local

# OS.
Thumbs.db

# Stage 2 transient artifacts (regenerated each run by migrate.yml).
outputs/.snippets-inventory.md
outputs/.lint-errors.md

# Metrics SQLite DB (local reporting cache, regenerated by pipeline runs).
outputs/.metrics.db
outputs/.metrics.db-journal
outputs/.metrics.db-wal
outputs/.metrics.db-shm

# Stage 1 replay cache (local-only, managed by scripts/stage1-replay.ts).
outputs/.stage1-cache/

# Trajectory replay JSONs (local-only, managed by scripts/trajectory-trace.ts;
# Layer 11 / Trajectory Review scaffold).
outputs/.trajectories/

# Compiled-at-runtime sidecar for danger-rules.ts (created by danger.yml)
scripts/lib/danger-rules.js
.claude/

# Captured failing-PR artifacts (local-only, managed by scripts/capture-failure.ts).
# Promote a case into fixtures/<validator>/{good,bad}-NN/ to make it a permanent
# regression fixture; the raw scratch capture stays out of git.
tools/calibrate-pipeline/fixtures/_captured/

# RAG BM25 index (local-only, regenerated by scripts/index-plans.ts / rag:index).
outputs/.rag-index.json
