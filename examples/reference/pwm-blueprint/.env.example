# ── Adapt this blueprint to YOUR app ──────────────────────────────────────────
# Copy to .env and fill in your app's values.

# ← YOUR APP'S BASE URL goes here (the migrated tests run against this).
URL_BASE=https://staging.example.com

# Optional: a separate production base URL (defaults to www.example.com).
# URL_BASE_PRODUCTION=https://www.example.com

# Environment selection: true = production base, anything else = staging base.
IS_PRODUCTION=false

# No shared test account is needed in the example: each test creates its own user
# via the signup API (see helper/api/accounts.api.ts). For your app, point that API
# at your own signup endpoint and credentials.
