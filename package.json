{
  "name": "pwmodernizer",
  "version": "0.0.1",
  "private": true,
  "description": "LLM-driven pipeline that migrates bad Playwright tests (Step 1), Cypress (Step 2), and Selenium (Step 3) into clean modern Playwright TypeScript.",
  "type": "module",
  "scripts": {
    "evaluate": "tsx scripts/evaluate.ts",
    "check:trivial": "tsx scripts/ast-diff-trivial-check.ts",
    "check:kb": "tsx scripts/kb-validate.ts",
    "check:examples": "tsx scripts/validate-examples.ts --warn",
    "check:assemble": "tsx scripts/assemble-prompts.ts --check",
    "check:envelope": "tsx scripts/plan-envelope-validate.ts --envelope examples/bad-playwright-01-flaky-waits/expected-plan.envelope.json",
    "assemble-prompts": "tsx scripts/assemble-prompts.ts --write",
    "calibrate": "tsx tools/calibrate-pipeline/run-calibration.ts",
    "lint": "eslint 'outputs/tests/**/*.ts'",
    "lint:fix": "eslint --fix 'outputs/tests/**/*.ts'",
    "typecheck": "tsc --noEmit -p outputs/tests/tsconfig.json",
    "typecheck:scripts": "tsc --noEmit -p tsconfig.json",
    "typecheck:all": "npm run typecheck:scripts && npm run typecheck",
    "test:parse": "playwright test --list outputs/tests/**/*.spec.ts",
    "validate:all": "npm run check:kb && npm run check:examples && npm run check:assemble && npm run check:envelope && npm run calibrate"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@playwright/test": "^1.56.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "ajv": "^8.20.0",
    "eslint": "^9.16.0",
    "eslint-plugin-playwright": "^2.10.4",
    "prettier": "^3.4.2",
    "ts-morph": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jurajjjjj1988/PWmodernizer.git"
  }
}
