{
  "name": "pwmodernizer",
  "version": "0.3.0",
  "private": true,
  "description": "LLM-driven pipeline that migrates bad Playwright tests (Step 1), Cypress (Step 2), and Selenium (Step 3) into clean modern Playwright TypeScript.",
  "type": "module",
  "scripts": {
    "evaluate": "tsx scripts/evaluate.ts",
    "check:trivial": "tsx scripts/ast-diff-trivial-check.ts",
    "check:kb": "tsx scripts/kb-validate.ts",
    "check:examples": "tsx scripts/validate-examples.ts --strict",
    "check:assemble": "tsx scripts/assemble-prompts.ts --check",
    "check:envelope": "tsx scripts/plan-envelope-validate.ts --envelope examples/bad-playwright-01-flaky-waits/expected-plan.envelope.json",
    "check:envelope:code": "tsx scripts/plan-envelope-validate.ts --envelope examples/bad-playwright-01-flaky-waits/expected-plan.envelope.json --code examples/bad-playwright-01-flaky-waits/expected-output.spec.ts",
    "check:derive": "bash -c 'set -e; for plan in examples/*/expected-plan.md; do [[ \"$plan\" == *reference* ]] && continue; out=$(mktemp); tsx scripts/derive-envelope.ts --plan \"$plan\" --out \"$out\" >/dev/null && tsx scripts/plan-envelope-validate.ts --envelope \"$out\" >/dev/null || { echo \"FAIL: $plan\"; exit 1; }; done; echo \"derive: 12/12 plans roundtrip cleanly\"'",
    "check:coverage": "tsx scripts/plan-code-coverage.ts --envelope examples/bad-playwright-01-flaky-waits/expected-plan.envelope.json --output examples/bad-playwright-01-flaky-waits --warn",
    "derive-envelope": "tsx scripts/derive-envelope.ts",
    "build-inventory": "tsx scripts/build-inventory.ts",
    "assemble-prompts": "tsx scripts/assemble-prompts.ts --write",
    "calibrate": "tsx tools/calibrate-pipeline/run-calibration.ts",
    "metrics:report": "tsx scripts/metrics-report.ts",
    "metrics:export": "tsx scripts/metrics-export.ts",
    "dashboard": "tsx scripts/dashboard.ts",
    "cost:report": "tsx scripts/cost-report.ts",
    "plan": "tsx scripts/plan-local.ts",
    "test:plan-local": "tsx --test scripts/plan-local.test.ts",
    "migrate": "tsx scripts/migrate-local.ts",
    "explain": "tsx scripts/explain-migration.ts",
    "triage": "tsx scripts/capture-failure.ts",
    "test:triage": "tsx --test scripts/capture-failure.test.ts",
    "test:migrate": "tsx --test scripts/migrate-local.test.ts",
    "test:triage-all": "tsx --test scripts/triage-all.test.ts",
    "test:lean": "tsx --test scripts/lean-profile.test.ts",
    "test:load-gate": "tsx --test scripts/conformance-load-gate.test.ts",
    "test:plan-dom-grounding": "tsx --test scripts/validate-plan-dom-grounding.test.ts",
    "test:output-spec": "tsx --test scripts/output-spec.test.ts",
    "test:binom": "tsx --test scripts/lib/binom.test.ts",
    "test:acceptance": "tsx --test scripts/acceptance-calibrate.test.ts",
    "test:assertion-coverage": "tsx --test scripts/assertion-coverage.test.ts",
    "calibrate:acceptance": "tsx scripts/acceptance-calibrate.ts",
    "check:assertions": "tsx scripts/assertion-coverage.ts --envelope examples/bad-playwright-01-flaky-waits/expected-plan.envelope.json --output examples/bad-playwright-01-flaky-waits/expected-output.spec.ts --strict",
    "test:evaluate": "tsx --test scripts/evaluate.test.ts",
    "test:explain": "tsx --test scripts/explain-migration.test.ts",
    "test:semantic": "tsx --test scripts/semantic-regression-check.test.ts",
    "test:report-metrics": "tsx --test scripts/validate-report-metrics.test.ts",
    "test:derive": "tsx --test scripts/derive-envelope.test.ts",
    "test:rag-map3": "tsx --test scripts/rag-map3-evaluator.test.ts",
    "triage:all": "tsx scripts/triage-all.ts",
    "stress:test-stage0": "tsx scripts/test-stage0.ts",
    "stage1:replay": "tsx scripts/stage1-replay.ts",
    "trajectory:trace": "tsx scripts/trajectory-trace.ts",
    "trajectory:show": "tsx scripts/trajectory-show.ts",
    "ast-diff:sweep": "tsx scripts/ast-diff-threshold-sweep.ts",
    "check:dom-ground": "tsx scripts/dom-ground.ts --url mock://always-resolve --probe examples/bad-playwright-01-flaky-waits/expected-output.spec.ts --report /tmp/dom-probe-smoke.json",
    "check:helper-usage": "tsx scripts/validate-helper-usage.ts",
    "check:dom-ground:live": "tsx scripts/dom-ground-live-calibrate.ts",
    "materialize:low-pins": "tsx scripts/materialize-low-confidence-pins.ts",
    "check:danger": "tsx scripts/danger-calibrate.ts",
    "lint": "eslint 'outputs/tests/**/*.ts'",
    "lint:fix": "eslint --fix 'outputs/tests/**/*.ts'",
    "typecheck": "tsc --noEmit -p outputs/tests/tsconfig.json",
    "typecheck:scripts": "tsc --noEmit -p tsconfig.json",
    "typecheck:all": "npm run typecheck:scripts && npm run typecheck",
    "test:parse": "playwright test --list outputs/tests/**/*.spec.ts",
    "validate:all": "npm run check:kb && npm run check:examples && npm run check:assemble && npm run check:envelope && npm run check:envelope:code && npm run check:derive && npm run check:coverage && npm run check:assertions && npm run check:helper-usage && npm run calibrate",
    "smoke": "npm run typecheck:all && npm run validate:all && npm run lint && npm run test:triage && npm run test:triage-all && npm run test:lean && npm run test:load-gate && npm run test:plan-dom-grounding && npm run test:output-spec && npm run test:run-against-sut && npm run test:repair-loop && npm run test:resolve-locator && npm run test:judge && npm run test:codemod && npm run test:binom && npm run test:acceptance && npm run test:assertion-coverage && npm run test:evaluate && npm run test:explain && npm run test:migrate && npm run test:plan-local && npm run test:semantic && npm run test:report-metrics && npm run test:derive && npm run test:measure-framework && npm run test:rag-ablation && npm run test:rag-map3",
    "quickstart": "tsx scripts/quickstart-check.ts",
    "try-it": "tsx scripts/try-it.ts",
    "dom:snapshot": "tsx scripts/dom-snapshot.ts",
    "changelog": "tsx scripts/generate-changelog.ts",
    "changelog:write": "tsx scripts/generate-changelog.ts --write",
    "baseline:selenium-java": "tsx scripts/baseline-compare-selenium-java.ts",
    "validate:plan-dom-grounding": "tsx scripts/validate-plan-dom-grounding.ts",
    "cache:report": "tsx scripts/measure-cache-hit-rate.ts",
    "cache:dry-run": "tsx scripts/claude-cached-call.ts --lens sdet --input-basename smoke --dry-run",
    "rag:index": "tsx scripts/index-plans.ts",
    "rag:retrieve": "tsx scripts/retrieval-bm25.ts",
    "rag:render": "tsx scripts/rag-context-render.ts",
    "rag:variance": "tsx scripts/rag-variance-report.ts",
    "rag:map3": "tsx scripts/rag-map3-evaluator.ts",
    "rag:eval": "tsx scripts/rag-map3-evaluator.ts --gate --quiet",
    "pilot:dry-run": "tsx scripts/pilot-dry-run.ts",
    "rag:ablation": "tsx scripts/rag-ablation.ts",
    "test:rag-ablation": "tsx --test scripts/rag-ablation.test.ts",
    "measure:frameworks": "tsx scripts/measure-framework.ts",
    "test:measure-framework": "tsx --test scripts/measure-framework.test.ts",
    "run:sut": "tsx scripts/run-against-sut.ts",
    "test:run-against-sut": "tsx --test scripts/run-against-sut.test.ts",
    "repair": "tsx scripts/repair-loop.ts",
    "test:repair-loop": "tsx --test scripts/repair-loop.test.ts",
    "resolve:locator": "tsx scripts/resolve-locator.ts",
    "test:resolve-locator": "tsx --test scripts/resolve-locator.test.ts",
    "judge": "tsx scripts/judge.ts",
    "test:judge": "tsx --test scripts/judge.test.ts",
    "codemod:cypress": "tsx scripts/cypress-codemod.ts",
    "test:codemod": "tsx --test scripts/cypress-codemod.test.ts"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@eslint/js": "^10.0.1",
    "@playwright/mcp": "^0.0.75",
    "@playwright/test": "^1.56.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "ajv": "^8.20.0",
    "better-sqlite3": "^11.7.0",
    "danger": "^13.0.7",
    "eslint": "^9.16.0",
    "eslint-plugin-playwright": "^2.10.4",
    "prettier": "^3.4.2",
    "tree-sitter": "^0.21.1",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-python": "^0.23.6",
    "ts-morph": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.61.0"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jurajjjjj1988/PWmodernizer.git"
  }
}
